    "zip": "wxt zip -b firefox --mv3",
    "zip:chrome": "wxt zip -b chrome",
    "compile": "vue-tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "tailwindcss": "^4.2.0",
    "vue": "^3.5.27"
  },
  "devDependencies": {
    "@wxt-dev/module-vue": "^1.0.3",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.4",
    "wxt": "^0.20.17"
  }
}
