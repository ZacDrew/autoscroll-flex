{
  "name": "wxt-vue-starter",
  "description": "manifest.json description",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "wxt -b firefox --mv2",
    "dev:chrome": "wxt -b chrome",
    "build": "wxt build -b firefox --mv3",
